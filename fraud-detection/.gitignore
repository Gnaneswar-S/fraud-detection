# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
.eggs/
dist/
build/

# Virtual environment
.venv/
venv/
env/

# Secrets — NEVER commit these
.env
!.env.example

# Model artefacts — too large for git (use DVC or cloud storage)
model/*.pkl
model/*.json
model/*.joblib
!model/.gitkeep
!model/generate_demo_model.py
!model/train.py

# Data — never commit PII data
data/raw/*.csv
data/raw/*.zip
data/raw/*.parquet
!data/raw/.gitkeep

# Results
results/

# DB files
*.db
*.sqlite

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

